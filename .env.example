# PostgreSQL / Prisma Accelerate connection string
DATABASE_URL=

# Random secret used to sign sessions — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# This app's own base URL. Must match the real deployed domain in production
# (used to build every auth callback and email link).
BETTER_AUTH_URL=http://localhost:3000

# Seeded admin account (prisma/seed.ts) — also the recipient for contact-form
# and status-change notification emails.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Gmail SMTP sender credentials for outgoing email (src/services/mail.ts).
# GOOGLE_CLIENT_ID holds the Gmail address; GOOGLE_CLIENT_SECRET holds an
# app password (https://support.google.com/accounts/answer/185833) — not
# your Google account password.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL used for SEO metadata (canonical URLs, sitemap, robots.txt).
# Falls back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
